# =============================================================================
# GP-DAT — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- LLM Configuration ---
LLM_PROVIDER=               
LLM_MODEL=
LLM_TEMPERATURE=
LLM_MAX_TOKENS=

# --- Apollo Provider (OAuth2 gateway — internal) ---
APOLLO_CLIENT_ID=your-apollo-client-id
APOLLO_CLIENT_SECRET=your-apollo-client-secret
APOLLO_TOKEN_URL=https://api-mgmt.boehringer-ingelheim.com:8065/api/oauth/token
APOLLO_BASE_URL=https://api-mgmt.boehringer-ingelheim.com:8065/apollo/llm-api

# --- Paths ---
TEMPLATE_DIR=data/templates
ENTERPRISE_DATA_DIR=data/enterprise_data
SQLITE_DB_PATH=data/gp-dat.db

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*
